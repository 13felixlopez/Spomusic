                            HeightRequest="120"
                            ItemsLayout="HorizontalList"
                            ItemsSource="{Binding RecommendedSongs}"
                            SelectionMode="None">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:SongItem">
                                    <Border
                                        Margin="0,0,10,0"
                                        Padding="8"
                                        BackgroundColor="#1E1E1E"
                                        Stroke="Transparent"
                                        WidthRequest="150">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="10" />
                                        </Border.StrokeShape>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=PlaySongCommand}" CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                        <Grid ColumnDefinitions="34,*">
                                            <Border
                                                BackgroundColor="#272727"
                                                HeightRequest="34"
                                                Stroke="Transparent"
                                                WidthRequest="34">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="5" />
                                                </Border.StrokeShape>
                                                <Image Aspect="AspectFill" Source="{Binding AlbumArt, Converter={StaticResource ByteArrayToImageSourceConverter}}" />
                                            </Border>
                                            <VerticalStackLayout
                                                Grid.Column="1"
                                                Margin="8,0,0,0"
                                                VerticalOptions="Center">
                                                <Label
                                                    FontSize="11"
                                                    MaxLines="1"
                                                    Text="{Binding Title}"
                                                    TextColor="White" />
                                                <Label
                                                    FontSize="10"
                                                    MaxLines="1"
                                                    Text="{Binding Artist}"
                                                    TextColor="#ADADAD" />
                                            </VerticalStackLayout>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Row="2" Spacing="6">
                        <Label
                            CharacterSpacing="1.2"
                            FontSize="12"
                            Text="Continuar escuchando"
                            TextColor="#A8A8A8" />
                        <CollectionView ItemsSource="{Binding ContinueListeningSongs}" SelectionMode="None">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:SongItem">
                                    <Border
                                        Margin="0,0,0,8"
                                        Padding="8"
                                        BackgroundColor="#1F1F1F"
                                        Stroke="Transparent">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="10" />
                                        </Border.StrokeShape>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=PlaySongCommand}" CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                        <Grid ColumnDefinitions="34,*">
                                            <Border
                                                BackgroundColor="#272727"
                                                HeightRequest="34"
                                                Stroke="Transparent"
                                                WidthRequest="34">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="5" />
                                                </Border.StrokeShape>
                                                <Image Aspect="AspectFill" Source="{Binding AlbumArt, Converter={StaticResource ByteArrayToImageSourceConverter}}" />
                                            </Border>
                                            <VerticalStackLayout
                                                Grid.Column="1"
                                                Margin="8,0,0,0"
                                                VerticalOptions="Center">
                                                <Label
                                                    FontSize="12"
                                                    MaxLines="1"
                                                    Text="{Binding Title}"
                                                    TextColor="White" />
                                                <Label
                                                    FontSize="10"
                                                    MaxLines="1"
                                                    Text="{Binding Artist}"
                                                    TextColor="#AFAFAF" />
                                            </VerticalStackLayout>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.RowSpan="5" IsVisible="{Binding IsQueuePanelOpen}">
            <BoxView Color="#66000000">
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding ToggleQueuePanelCommand}" />
                </BoxView.GestureRecognizers>
            </BoxView>
            <Border
                x:Name="QueuePanel"
                Padding="14"
                BackgroundColor="#141414"
                HorizontalOptions="End"
                Stroke="#2DFFFFFF"
                WidthRequest="340">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="0" />
                </Border.StrokeShape>
                <Grid RowDefinitions="Auto,Auto,*">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <Border
                            Padding="10"
                            BackgroundColor="#1F1F1F"
                            Stroke="Transparent">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleQueuePanelCommand}" />
                            </Border.GestureRecognizers>
                            <Path
                                Aspect="Uniform"
                                Data="{StaticResource BackIcon}"
                                Fill="White"
                                HeightRequest="16"
                                WidthRequest="16" />
                        </Border>
                        <Label
                            Grid.Column="1"
                            FontAttributes="Bold"
                            FontSize="20"
                            Text="Cola actual"
                            TextColor="White"
                            VerticalOptions="Center" />
                    </Grid>
                    <Label
                        Grid.Row="1"
                        Margin="0,10,0,8"
                        FontSize="11"
                        Text="Mantén pulsado y arrastra para reordenar"
                        TextColor="#A8A8A8" />
                    <CollectionView
                        x:Name="QueueCollectionView"
                        Grid.Row="2"
                        ItemsSource="{Binding QueueSongs}"
                        SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:SongItem">
                                <Border
                                    Margin="0,0,0,8"
                                    Padding="10"
                                    BackgroundColor="#1F1F1F"
                                    Stroke="#22FFFFFF">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="10" />
                                    </Border.StrokeShape>
                                    <Border.GestureRecognizers>
                                        <DragGestureRecognizer DragStarting="OnQueueItemDragStarting" />
                                        <DropGestureRecognizer AllowDrop="True" Drop="OnQueueItemDrop" />
                                    </Border.GestureRecognizers>
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <Label
                                            FontSize="18"
                                            Text="≡"
                                            TextColor="#9ADCAE"
                                            VerticalOptions="Center" />
                                        <VerticalStackLayout
                                            Grid.Column="1"
                                            Margin="10,0,8,0"
                                            VerticalOptions="Center">
                                            <Label
                                                FontAttributes="Bold"
                                                FontSize="12"
                                                MaxLines="1"
                                                Text="{Binding Title}"
                                                TextColor="White" />
                                            <Label
                                                FontSize="10"
                                                MaxLines="1"
                                                Text="{Binding Artist}"
                                                TextColor="#AFAFAF" />
                                        </VerticalStackLayout>
                                        <Border
                                            Grid.Column="2"
                                            Padding="8"
                                            Stroke="Transparent">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=PlaySongCommand}" CommandParameter="{Binding .}" />
                                            </Border.GestureRecognizers>
                                            <Path
                                                Aspect="Uniform"
                                                Data="{StaticResource PlayIcon}"
                                                Fill="#C6FFD8"
                                                HeightRequest="14"
                                                WidthRequest="14" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.RowSpan="5" IsVisible="{Binding IsLyricsFullScreen}">
            <Grid.GestureRecognizers>
                <SwipeGestureRecognizer Command="{Binding IncreaseLyricsFontSizeCommand}" Direction="Up" />
                <SwipeGestureRecognizer Command="{Binding DecreaseLyricsFontSizeCommand}" Direction="Down" />
                <SwipeGestureRecognizer Command="{Binding NextCommand}" Direction="Left" />
                <SwipeGestureRecognizer Command="{Binding PreviousCommand}" Direction="Right" />
                <TapGestureRecognizer Command="{Binding TogglePlayPauseCommand}" NumberOfTapsRequired="2" />
            </Grid.GestureRecognizers>
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Offset="0.0" Color="{Binding CurrentSong.AccentColorHex, Converter={StaticResource HexColorConverter}}" />
                    <GradientStop Offset="0.95" Color="#121212" />
                </LinearGradientBrush>
            </Grid.Background>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid
                Grid.Row="0"
                Margin="16,50,16,0"
                ColumnDefinitions="*,Auto"
                HeightRequest="50">
                <Label
                    FontAttributes="Bold"
                    FontSize="12"
                    Text="LETRAS"
                    TextColor="#E8FFF1"
                    VerticalOptions="Center" />
                <HorizontalStackLayout Grid.Column="1" Spacing="8">
                    <Border
                        Padding="8"
                        BackgroundColor="#30000000"
                        HeightRequest="50"
                        Stroke="Transparent"
                        WidthRequest="50">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="25" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding DownloadLyricsCommand}" />
                        </Border.GestureRecognizers>
                        <Path
                            Aspect="Uniform"
                            Data="{StaticResource DownloadIcon}"
                            Fill="White" />
                    </Border>
                    <Border
                        Padding="12"
                        BackgroundColor="#30000000"
                        HeightRequest="50"
                        Stroke="Transparent"
                        WidthRequest="50">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="25" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSyncMenuClicked" />
                        </Border.GestureRecognizers>
                        <Label
                            FontSize="22"
                            HorizontalOptions="Center"
                            Text="⋮"
                            TextColor="White"
                            VerticalOptions="Center" />
                    </Border>
                    <Border
                        Padding="12"
                        BackgroundColor="#30000000"
                        HeightRequest="50"
                        Stroke="Transparent"
                        WidthRequest="50">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="25" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleLyricsFullScreenCommand}" />
                        </Border.GestureRecognizers>
                        <Path
                            Aspect="Uniform"
                            Data="{StaticResource CloseIcon}"
                            Fill="White" />
                    </Border>
                </HorizontalStackLayout>
            </Grid>

            <CollectionView
                x:Name="LyricsCollectionView"
                Grid.Row="1"
                Margin="22,16,22,12"
                ItemsSource="{Binding FullLyrics}"
                SelectionMode="None"
                VerticalScrollBarVisibility="Never">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="services:LyricLine">
                        <Label
                            Margin="0,4"
                            FontAttributes="Bold"
                            FontSize="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=LyricsFontSize}"
                            HorizontalTextAlignment="Center"
                            LineHeight="1.18">
                            <Label.FormattedText>
                                <MultiBinding Converter="{StaticResource KaraokeLineFormattedMultiConverter}">
                                    <Binding Path="Text" />
                                    <Binding Path="Index" />
                                    <Binding Path="CurrentLyricIndex" Source="{RelativeSource AncestorType={x:Type vm:MainViewModel}}" />
                                    <Binding Path="CurrentLyricWordProgress" Source="{RelativeSource AncestorType={x:Type vm:MainViewModel}}" />
                                    <Binding Path="IsHighContrastLyrics" Source="{RelativeSource AncestorType={x:Type vm:MainViewModel}}" />
                                </MultiBinding>
                            </Label.FormattedText>
                            <Label.Opacity>
                                <MultiBinding Converter="{StaticResource LyricLineOpacityMultiConverter}">
                                    <Binding Path="Index" />
                                    <Binding Path="CurrentLyricIndex" Source="{RelativeSource AncestorType={x:Type vm:MainViewModel}}" />
                                    <Binding Path="IsHighContrastLyrics" Source="{RelativeSource AncestorType={x:Type vm:MainViewModel}}" />
                                </MultiBinding>
                            </Label.Opacity>
                            <Label.Scale>
                                <MultiBinding Converter="{StaticResource LyricLineScaleMultiConverter}">
                                    <Binding Path="Index" />
                                    <Binding Path="CurrentLyricIndex" Source="{RelativeSource AncestorType={x:Type vm:MainViewModel}}" />
                                </MultiBinding>
                            </Label.Scale>
                        </Label>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Border
                Grid.Row="2"
                Margin="16,0,16,26"
                Padding="10,8"
                BackgroundColor="#1A000000"
                Stroke="#28FFFFFF"
                ZIndex="2">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>
                <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto,Auto" RowDefinitions="Auto,Auto">
                    <Label
                        Grid.Row="0"
                        Grid.Column="0"
                        FontAttributes="Bold"
                        FontSize="10"
                        Text="Karaoke Pro"
                        TextColor="White"
                        VerticalOptions="Center" />
                    <Label
                        Grid.Row="0"
                        Grid.Column="1"
                        FontSize="10"
                        HorizontalTextAlignment="End"
                        Text="{Binding LyricLeadMs, StringFormat='{}+{0} ms'}"
                        TextColor="#F3FFF6"
                        VerticalOptions="Center" />
                    <Label
                        Grid.Row="1"
                        Grid.Column="1"
                        Margin="0,0,0,0"
                        FontAttributes="Bold"
                        FontSize="10"
                        HorizontalTextAlignment="End"
                        Text="{Binding LyricSyncQuality, StringFormat='{}Sync {0}'}"
                        TextColor="{Binding LyricSyncQualityColor}"
                        VerticalOptions="Center" />
                    <Slider
                        Grid.Row="1"
                        Grid.Column="0"
                        Margin="0,4,8,0"
                        Maximum="1200"
                        MaximumTrackColor="#66FFFFFF"
                        Minimum="0"
                        MinimumTrackColor="White"
                        ThumbColor="White"
                        Value="{Binding LyricLeadMs}" />
                    <Button
                        Grid.Row="0"
                        Grid.RowSpan="2"
                        Grid.Column="2"
                        Margin="6,0,0,0"
                        BackgroundColor="#28000000"
                        Command="{Binding DecreaseLyricsFontSizeCommand}"
                        CornerRadius="8"
                        FontSize="11"
                        HeightRequest="34"
                        Text="A-"
                        TextColor="White"
                        WidthRequest="44" />
                    <Button
                        Grid.Row="0"
                        Grid.RowSpan="2"
                        Grid.Column="3"
                        Margin="6,0,0,0"
                        BackgroundColor="#28000000"
                        Command="{Binding IncreaseLyricsFontSizeCommand}"
                        CornerRadius="8"
                        FontSize="11"
                        HeightRequest="34"
                        Text="A+"
                        TextColor="White"
                        WidthRequest="44" />
                    <Button
                        Grid.Row="0"
                        Grid.RowSpan="2"
                        Grid.Column="4"
                        Margin="6,0,0,0"
                        BackgroundColor="#28000000"
                        Command="{Binding ToggleHighContrastLyricsCommand}"
                        CornerRadius="8"
                        FontSize="11"
                        HeightRequest="34"
                        Text="HC"
                        TextColor="White"
                        WidthRequest="48" />
                    <Button
                        Grid.Row="0"
                        Grid.RowSpan="2"
                        Grid.Column="5"
                        Margin="6,0,0,0"
                        BackgroundColor="#213629"
                        Command="{Binding TapSyncCommand}"
                        CornerRadius="8"
                        FontSize="11"
                        HeightRequest="34"
                        Text="Sync"
                        TextColor="#DDFDE8"
                        WidthRequest="56" />
                    <Border
                        Grid.Row="0"
                        Grid.RowSpan="2"
                        Grid.Column="6"
                        Margin="6,0,0,0"
                        Padding="10"
                        BackgroundColor="#28000000"
                        HeightRequest="34"
                        Stroke="Transparent"
                        WidthRequest="42">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding DeleteDownloadedLyricsCommand}" />
                        </Border.GestureRecognizers>
                        <Path
                            Aspect="Uniform"
                            Data="{StaticResource TrashIcon}"
                            Fill="White"
                            HeightRequest="14"
                            WidthRequest="14" />
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
